                        <Input name="onStop" type="1" type_size="1" nature="3" inner="0" tooltip="Box behavior stops when a signal is received on this input." id="3" />
                        <Output name="onStopped" type="1" type_size="1" nature="1" inner="0" tooltip="Signal sent when box behavior is finished." id="4" />
                        <Output name="onTranscriptionReady" type="3" type_size="1" nature="2" inner="0" tooltip="" id="5" />
                        <Output name="onTranscriptionFailed" type="1" type_size="1" nature="2" inner="0" tooltip="" id="6" />
                        <Parameter name="api_url" inherits_from_parent="0" content_type="3" value="https://c0l4m0n1c0.ydns.eu:19367/api3/stt/vosk/fast" default_value="http://127.0.0.1:5000/stt/vosk" custom_choice="0" tooltip="" id="7" />
                      </Box>
                      <Box name="smart_ai_online" id="20" localization="8" tooltip="" x="168" y="123">
                        <dialogFile>../smart_ai_online/smart_ai_online.dlg</dialogFile>
                        <bitmap>media/images/box/box-dialog.png</bitmap>
                        <script language="4">
                          <content>
                            <![CDATA[]]>
                          </content>
                        </script>
                        <Input name="onLoad" type="1" type_size="1" nature="0" inner="1" tooltip="Signal sent when diagram is loaded." id="1" />
                        <Input name="onStart" type="1" type_size="1" nature="2" inner="0" tooltip="Box behavior starts when a signal is received on this input." id="2" />
                        <Input name="onStop" type="1" type_size="1" nature="3" inner="0" tooltip="Box behavior stops when a signal is received on this input." id="3" />
                        <Output name="onStopped" type="1" type_size="1" nature="1" inner="0" tooltip="Signal sent when box behavior is finished." id="4" />
                        <Output name="changeTopicAI" type="1" type_size="1" nature="2" inner="0" tooltip="" id="5" />
                        <Output name="exit" type="1" type_size="1" nature="2" inner="0" tooltip="" id="6" />
                        <Output name="domandaAI" type="3" type_size="1" nature="2" inner="0" tooltip="" id="7" />
                        <Output name="onlineAudio" type="1" type_size="1" nature="2" inner="0" tooltip="" id="8" />
                        <Output name="stopOnlineAudio" type="1" type_size="1" nature="2" inner="0" tooltip="" id="9" />
                        <Output name="fastAudio" type="1" type_size="1" nature="2" inner="0" tooltip="" id="10" />
