            <Box name="set_AI_OFF" id="19" localization="8" tooltip="Definisce la variabile globale Gemini" x="81" y="204">
              <bitmap>media/images/box/box-python-script.png</bitmap>
              <script language="4">
                <content>
                  <![CDATA[import qi    # per gestire la funzione async
class MyClass(GeneratedClass):
    def __init__(self):
        GeneratedClass.__init__(self)

    def onLoad(self):
        self.memory = ALProxy("ALMemory")
        self.tts = self.session().service("ALTextToSpeech")
        self.anim_player = self.session().service("ALAnimationPlayer")
        pass

    def onUnload(self):
        pass

    def onInput_onStart(self):
        # 1. Saluto iniziale con animazione
        qi.async(self.tts.say, "Ciao! Sono NAO ed è un piacere essere qui con te!")
        self.anim_player.run("animations/Stand/Gestures/Hey_1")
        #self.tts.say("Sono NAO ed è un piacere essere qui con te!")

        # Inizializza la variabile globale aiOnOff
        self.memory.insertData("aiOnOff", 0)
        self.logger.info("Variabile aiOnOff inizializzata a 0")
        self.onStopped()

    def onInput_onStop(self):
        self.onUnload()
        self.onStopped()]]>
                </content>
              </script>
