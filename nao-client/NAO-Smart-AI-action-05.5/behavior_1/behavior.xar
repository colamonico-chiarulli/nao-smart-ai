            <Box name="switch_AI-ON-OFF" id="24" localization="8" tooltip="Verifica e inverte il valore di aiOnOff" x="523" y="217">
              <bitmap>media/images/box/box-python-script.png</bitmap>
              <script language="4">
                <content>
                  <![CDATA[import random

class MyClass(GeneratedClass):
    def __init__(self):
        GeneratedClass.__init__(self)

    def onLoad(self):
        self.memory = ALProxy("ALMemory")
        self.tts = ALProxy("ALTextToSpeech")
        self.anim_player = self.session().service("ALAnimationPlayer")

        # Frasi casuali (per avvio)
        self.gemini_start_phrases = [
            "Che bello, ora sarò più intelligente",
            "attivo l'intelligenza artificiale e dialoghiamo meglio",
            "Bene! Così possiamo parlare di qualsiasi cosa"
        ]
        # Prima volta online?
        self.firstTime = True
        pass

    def onUnload(self):
        pass

    def onInput_onStart(self):

        if self.firstTime:
            self.firstTime = False
            # Frase casuale di attivazione + MysticalPower
            phrase = random.choice(self.gemini_start_phrases)
            self.tts.say(phrase)
            try:
                self.anim_player.run("animations/Stand/Waiting/MysticalPower_1")
            except:
                pass


        # Leggi il valore corrente
        current_value = self.memory.getData("aiOnOff")
        if current_value == 1:
            self.memory.insertData("aiOnOff", 0)
            self.tts.say("offline")
            self.geminiOFF()
        else:
            self.memory.insertData("aiOnOff", 1)
            self.tts.say("online")
            self.geminiON()

    def onInput_onStop(self):
        self.onUnload()
        self.onStopped()]]>
                </content>
              </script>
